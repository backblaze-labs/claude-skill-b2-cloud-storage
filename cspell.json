{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "globRoot": ".",
  "files": [
    "README.md",
    "b2-cloud-storage/**/*.md",
    "b2-cloud-storage/**/*.py",
    "tests/**/*.py",
    "*.md"
  ],
  "ignorePaths": [
    ".git/**",
    "node_modules/**",
    ".cache/**",
    "**/*.lock",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml"
  ],
  "words": [
    "agentskills",
    "agentskillsmarket",
    "allpublic",
    "allprivate",
    "anthropic",
    "anthropics",
    "appkey",
    "argparse",
    "autoupdate",
    "Backblaze",
    "backblaze",
    "blze",
    "bzl",
    "claudeskills",
    "claudemarketplaces",
    "cloudflare",
    "contentsha",
    "cspell",
    "deduplication",
    "dryrun",
    "fileid",
    "frontmatter",
    "gpenacastellanos",
    "ietf",
    "isort",
    "jdeleon",
    "keyid",
    "lhm",
    "lifecycle",
    "lobehub",
    "marketcli",
    "markdownlint",
    "mertbuilds",
    "monorepo",
    "myproject",
    "mypy",
    "noqa",
    "noreply",
    "npx",
    "object-storage",
    "objstorage",
    "pawgrammer",
    "playbook",
    "presigned",
    "pycache",
    "pycodestyle",
    "pyflakes",
    "pyproject",
    "pytest",
    "pyupgrade",
    "pyyaml",
    "ruff",
    "shubovych",
    "skillhub",
    "skillsllm",
    "skillsmp",
    "skillset",
    "soc",
    "subcommand",
    "subcommands",
    "subdomains",
    "tfstate",
    "travisvn",
    "turnstile",
    "unhide",
    "venv",
    "verge",
    "yamllint"
  ],
  "flagWords": [],
  "allowCompoundWords": true,
  "minWordLength": 4,
  "ignoreRegExpList": [
    "/0x[a-f0-9]+/g",
    "/[a-f0-9]{7,}/g",
    "/https?:\\/\\/\\S+/g",
    "/`[^`]+`/g"
  ]
}
